---
import Base from '../../layouts/Base.astro';
import Footer from '../../components/Footer.astro';

const github = 'https://github.com/kldzj/pzmod';
const sponsor = 'https://github.com/sponsors/kldzj';

const guides = [
  {
    href: '/guides/add-workshop-mods-to-project-zomboid-server',
    title: 'Add Steam Workshop mods to a PZ dedicated server',
    blurb: 'What Mods= and WorkshopItems= do in servertest.ini, how to find mod IDs, and the mistakes to avoid.',
  },
  {
    href: '/guides/project-zomboid-mod-load-order',
    title: 'Project Zomboid mod load order, explained',
    blurb: 'Why the Mods= order matters, why WorkshopItems order does not, and where maps fit in.',
  },
  {
    href: '/guides/fix-project-zomboid-mod-dependency-errors',
    title: "Fix mod dependency and 'mod is missing' errors",
    blurb: 'The common causes of dependency errors, and how to catch them before the server boots.',
  },
];
---

<Base
  title="Project Zomboid server guides · pzmod"
  description="Practical guides for running a modded Project Zomboid dedicated server: adding Workshop mods, load order, and fixing dependency errors."
>
  <header class="sticky top-0 z-50 border-b border-border/70 bg-bg/80 backdrop-blur-md">
    <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-3.5">
      <a href="/" class="group flex items-center gap-2 font-mono text-lg font-bold tracking-tight">
        <span class="text-accent transition-transform group-hover:rotate-90">◆</span>
        <span>pzmod</span>
      </a>
      <div class="flex items-center gap-1 sm:gap-2">
        <a href="/#install" class="hidden rounded-md px-3 py-2 text-sm text-muted transition-colors hover:text-fg md:inline-block">Install</a>
        <a href={github} target="_blank" rel="noopener" class="rounded-md px-3 py-2 text-sm text-muted transition-colors hover:text-fg">GitHub</a>
        <a href={sponsor} target="_blank" rel="noopener" class="ml-1 inline-flex items-center gap-1.5 rounded-md border border-accent/40 bg-accent/10 px-3.5 py-2 text-sm font-medium text-accent-bright transition-colors hover:bg-accent/20">
          <span aria-hidden="true">♥</span> Sponsor
        </a>
      </div>
    </nav>
  </header>

  <main class="mx-auto max-w-3xl px-6 py-16 sm:py-20">
    <p class="font-mono text-sm text-accent">Guides</p>
    <h1 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl">Running a modded PZ server</h1>
    <p class="mt-4 text-lg leading-relaxed text-muted">
      Practical, no-nonsense guides for managing mods on a Project Zomboid dedicated server, from
      adding your first Workshop mod to sorting out load order and dependency errors.
    </p>

    <div class="mt-10 grid gap-5">
      {guides.map((g) => (
        <a href={g.href} class="card block p-6">
          <h2 class="text-lg font-semibold text-fg">{g.title}</h2>
          <p class="mt-2 text-sm leading-relaxed text-muted">{g.blurb}</p>
          <span class="mt-3 inline-block font-mono text-sm text-accent-bright">Read guide &rarr;</span>
        </a>
      ))}
    </div>
  </main>
  <Footer />
</Base>
