---
const install = 'curl -fsSL https://pzmod.dev/install.sh | bash';
const releases = 'https://github.com/kldzj/pzmod/releases';

const steps = [
  { n: '1', title: 'Add your server', body: 'Point pzmod at your servertest.ini and pick Build 41 or 42. Manage as many servers as you like.' },
  { n: '2', title: 'Search & add mods', body: 'Find mods in the Workshop and add them. Dependencies are pulled in for you automatically.' },
  { n: '3', title: 'Validate & save', body: 'Run a dry-run validation, fix anything it flags, then save. A backup is taken before every write.' },
];
---

<section id="install" class="relative mx-auto max-w-6xl px-6 py-20 sm:py-24">
  <div class="mx-auto max-w-2xl text-center">
    <p class="font-mono text-sm text-accent">Quick start</p>
    <h2 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl">Up and running in a minute</h2>
    <p class="mt-4 text-muted">Install on Linux or macOS with one command:</p>
  </div>

  <div class="mx-auto mt-8 max-w-3xl">
    <div class="flex items-stretch overflow-hidden rounded-lg border border-border bg-surface font-mono text-sm">
      <span class="hidden select-none items-center px-4 text-accent sm:flex" aria-hidden="true">$</span>
      <code id="install-cmd" class="flex-1 overflow-x-auto whitespace-nowrap px-4 py-3.5 text-fg sm:pl-0">{install}</code>
      <button
        id="copy-btn"
        type="button"
        data-cmd={install}
        class="flex shrink-0 items-center gap-1.5 border-l border-border bg-elevated px-4 text-xs font-medium text-muted transition-colors hover:bg-accent/10 hover:text-accent-bright"
      >
        <span data-copy-label>Copy</span>
      </button>
    </div>
    <p class="mt-3 text-center text-sm text-muted">
      On Windows, run <code class="rounded bg-surface px-1.5 py-0.5 font-mono text-xs text-accent-bright">irm https://pzmod.dev/install.ps1 | iex</code> in PowerShell.
      Also available as a <a href="https://github.com/kldzj/pzmod#docker" target="_blank" rel="noopener" class="text-accent-bright underline-offset-4 hover:underline">Docker image</a>
      or a <a href={releases} target="_blank" rel="noopener" class="text-accent-bright underline-offset-4 hover:underline">direct download</a>.
    </p>
  </div>

  <div class="mx-auto mt-14 grid max-w-4xl gap-5 sm:grid-cols-3">
    {steps.map((s) => (
      <div class="card p-6">
        <div class="flex h-9 w-9 items-center justify-center rounded-full border border-accent/30 bg-accent/10 font-mono text-sm font-bold text-accent-bright">
          {s.n}
        </div>
        <h3 class="mt-4 font-semibold text-fg">{s.title}</h3>
        <p class="mt-2 text-sm leading-relaxed text-muted">{s.body}</p>
      </div>
    ))}
  </div>
</section>

<script>
  const btn = document.getElementById('copy-btn');
  const label = btn?.querySelector('[data-copy-label]');
  btn?.addEventListener('click', async () => {
    const cmd = btn.getAttribute('data-cmd') ?? '';
    try {
      await navigator.clipboard.writeText(cmd);
      if (label) {
        const prev = label.textContent;
        label.textContent = '✓ Copied';
        btn.classList.add('text-ok');
        setTimeout(() => {
          label.textContent = prev;
          btn.classList.remove('text-ok');
        }, 1600);
      }
    } catch {
      /* clipboard unavailable, no-op */
    }
  });
</script>
